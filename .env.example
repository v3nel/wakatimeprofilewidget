# WakaTime API key used to fetch coding stats.
# If the raw key fails, try using the base64-encoded key because the app sends it with Basic auth.
WAKATIME_API_KEY=your_wakatime_api_key_here

# GitHub token loaded by the app config.
# Currently required by config but not used in the main flow.
GITHUB_TOKEN=your_github_token_here

# Discord application ID from the Discord Developer Portal.
DISCORD_APP_ID=your_discord_application_id_here

# Discord bot token from the Bot page in the Discord Developer Portal.
BOT_TOKEN=your_discord_bot_token_here

# Your Discord user ID. Enable Developer Mode in Discord, then copy your user ID.
DISCORD_USER_ID=your_discord_user_id_here
